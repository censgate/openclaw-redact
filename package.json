{
  "name": "@censgate/openclaw-redact",
  "version": "0.1.0",
  "description": "OpenClaw plugin for privacy-preserving LLM interactions via PII redaction",
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md"
  ],
  "openclaw": {
    "extensions": ["./dist/openclaw-plugin.js"]
  },
  "scripts": {
    "build": "tsc",
    "clean": "make clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:verification": "vitest run --config vitest.verification.config.ts",
    "test:openclaw-e2e": "vitest run --config vitest.openclaw-e2e.config.ts",
    "benchmark": "tsx benchmarks/http-latency.bench.ts",
    "benchmark:openclaw-gateway": "node benchmarks/openclaw-gateway-latency.mjs",
    "lint": "eslint src/ tests/ verification/",
    "lint:fix": "eslint src/ tests/ verification/ --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "redaction",
    "pii",
    "privacy",
    "llm",
    "censgate"
  ],
  "author": "Censgate <oss@censgate.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/censgate/openclaw-redact.git"
  },
  "bugs": {
    "url": "https://github.com/censgate/openclaw-redact/issues"
  },
  "homepage": "https://github.com/censgate/openclaw-redact#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@mariozechner/pi-agent-core": "^0.66.1",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "openclaw": "^2026.4.15",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "uuid": "^11.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

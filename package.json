{
  "name": "@censgate/openclaw-redact",
  "version": "0.1.4",
  "description": "OpenClaw plugin for privacy-preserving LLM interactions via PII redaction",
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "scripts/sync-openclaw-plugin-version.mjs",
    "scripts/sync-openclaw-plugin-json-schema.mjs",
    "LICENSE",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/openclaw-plugin.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.24",
      "minGatewayVersion": "2026.4.24"
    },
    "build": {
      "openclawVersion": "2026.4.24",
      "pluginSdkVersion": "2026.4.24"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "make clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "sync-plugin-version": "node scripts/sync-openclaw-plugin-version.mjs",
    "version-packages": "changeset version && npm run sync-plugin-version && npm install --package-lock-only --no-fund --no-audit",
    "prepublishOnly": "npm run sync-plugin-version && npm run build && node scripts/sync-openclaw-plugin-json-schema.mjs",
    "sync-plugin-json-schema": "node scripts/sync-openclaw-plugin-json-schema.mjs"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "redaction",
    "pii",
    "privacy",
    "llm",
    "censgate"
  ],
  "author": "Censgate <oss@censgate.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/censgate/openclaw-redact.git"
  },
  "bugs": {
    "url": "https://github.com/censgate/openclaw-redact/issues"
  },
  "homepage": "https://github.com/censgate/openclaw-redact#readme",
  "engines": {
    "node": ">=22.14.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@mariozechner/pi-agent-core": "^0.66.1",
    "@types/node": "^24.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "openclaw": "^2026.4.20",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "axios": "^1.15.0",
    "fast-xml-parser": "^5.7.0",
    "postcss": "^8.5.10",
    "protobufjs": "^7.5.5",
    "tar": "^7.5.11",
    "uuid": "^14.0.0",
    "@anthropic-ai/sdk": "^0.91.1"
  },
  "publishConfig": {
    "access": "public"
  }
}

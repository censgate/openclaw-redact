{
  "gateway": {
    "mode": "local",
    "port": 18789
  },
  "models": {
    "providers": {
      "censgate-mock": {
        "baseUrl": "http://mock-llm:3000/v1",
        "api": "openai-completions",
        "apiKey": "mock-key",
        "models": [
          {
            "id": "gpt-4o-mini",
            "name": "Mock GPT",
            "reasoning": false,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "censgate-mock/gpt-4o-mini"
      }
    }
  },
  "plugins": {
    "allow": ["censgate-redact"],
    "entries": {
      "censgate-redact": {
        "enabled": true,
        "config": {
          "http": {
            "endpoint": "http://redact:8080",
            "timeoutMs": 30000,
            "language": "en",
            "docker": {
              "enabled": false
            }
          }
        }
      }
    }
  }
}
